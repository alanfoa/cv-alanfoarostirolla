---
import { education } from "../data/info";
---

<section id="education" class="section reveal mx-auto max-w-4xl px-4 py-28">
  <h2 class="mb-14 text-center text-3xl font-bold text-white max-md:text-2xl">
    <span class="text-gradient">Educación</span>
  </h2>

  <div class="card-glass reveal rounded-2xl p-8 transition-all duration-300 hover:glow-secondary">
    <h3 class="mb-1 text-xl font-bold text-white">{education.title}</h3>
    <p class="mb-1 text-primary">{education.institution}</p>
    <p class="mb-6 text-sm text-gray-400">{education.status}</p>

    <div class="mb-6">
      <h4 class="mb-3 text-sm font-semibold uppercase tracking-wider text-gray-500">
        Materias y Conocimientos Clave
      </h4>
      <div class="flex flex-wrap gap-2">
        {education.subjects.map((subject) => (
          <span class="rounded-full border border-dark-border bg-dark-bg px-3.5 py-1.5 text-sm font-medium text-gray-300 transition-all duration-300 hover:border-primary/50 hover:text-primary">
            {subject}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
