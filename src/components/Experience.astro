---
import { experiences } from "../data/info";
---

<section id="experience" class="section reveal mx-auto max-w-4xl px-4 py-28">
  <h2 class="mb-14 text-center text-3xl font-bold text-white max-md:text-2xl">
    Experiencia <span class="text-gradient">Laboral</span>
  </h2>

  <div class="relative">
    <div id="timeline-line" class="absolute left-8 top-0 h-full w-0.5 bg-dark-border max-md:left-6"></div>

    <div class="space-y-12">
      {experiences.map((exp, idx) => (
        <div class="timeline-item relative pl-20 max-md:pl-16">
          <div class="timeline-dot absolute left-8 top-1.5 z-10 h-4 w-4 rounded-full border-2 border-primary bg-dark-bg max-md:left-6"></div>

          <div
            class="card-glass reveal rounded-2xl p-6 transition-all duration-300 hover:glow-primary"
            class:list={[`stagger-${(idx % 2) + 1}`]}
          >
            <span class="mb-2 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
              {exp.period}
            </span>
            <h3 class="mb-0.5 text-lg font-bold text-white">{exp.role}</h3>
            <p class="mb-4 text-sm text-secondary/80">{exp.organization}</p>

            <ul class="space-y-2">
              {exp.items.map((item) => (
                <li class="flex items-start gap-3 text-sm text-gray-400">
                  <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-secondary"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const items = document.querySelectorAll(".timeline-item");
          const line = document.getElementById("timeline-line");
          items.forEach((item, i) => {
            setTimeout(() => {
              const dot = item.querySelector(".timeline-dot");
              if (dot) {
                dot.style.backgroundColor = "var(--color-primary)";
                dot.style.boxShadow = "0 0 10px var(--color-primary)";
              }
            }, i * 200);
          });
          if (line) {
            line.style.background =
              "linear-gradient(to bottom, var(--color-primary), var(--color-secondary))";
            line.style.transition = "background 1s ease";
          }
          observer.disconnect();
        }
      });
    },
    { threshold: 0.2 }
  );

  const section = document.getElementById("experience");
  if (section) observer.observe(section);
</script>
