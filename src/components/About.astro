---
import { about } from "../data/info";
---

<section id="about" class="section reveal mx-auto max-w-4xl px-4 py-28">
  <h2 class="mb-12 text-center text-3xl font-bold text-white max-md:text-2xl">
    <span class="text-gradient">Sobre mí</span>
  </h2>

  <div class="space-y-5 text-lg leading-relaxed text-gray-300 max-md:text-base">
    {about.map((p, i) => (
      <p class="reveal" class:list={[`stagger-${i + 1}`]}>{p}</p>
    ))}
  </div>
</section>
