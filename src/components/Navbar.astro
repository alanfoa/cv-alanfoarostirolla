---
const links = [
  { label: "Inicio", href: "#hero" },
  { label: "Sobre mí", href: "#about" },
  { label: "Stack", href: "#stack" },
  { label: "Proyectos", href: "#projects" },
  { label: "Experiencia", href: "#experience" },
  { label: "Educación", href: "#education" },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-transform duration-300">
  <div class="card-glass mx-auto mt-4 flex max-w-3xl items-center justify-center gap-6 rounded-full px-6 py-3 shadow-lg max-md:mx-4 max-md:gap-3 max-md:px-4 max-md:text-sm">
    {
      links.map((link) => (
        <a
          href={link.href}
          class="text-gray-400 transition-colors duration-200 hover:text-white"
        >
          {link.label}
        </a>
      ))
    }
  </div>
</nav>

<script>
  let lastScroll = 0;
  const navbar = document.getElementById("navbar");

  window.addEventListener("scroll", () => {
    const currentScroll = window.scrollY;
    if (currentScroll > lastScroll && currentScroll > 100) {
      navbar.style.transform = "translateY(-120%)";
    } else {
      navbar.style.transform = "translateY(0)";
    }
    lastScroll = currentScroll;
  });
</script>
