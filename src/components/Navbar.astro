---
const links = [
  { label: "Inicio", href: "#hero" },
  { label: "Sobre mí", href: "#about" },
  { label: "Stack", href: "#stack" },
  { label: "Proyectos", href: "#projects" },
  { label: "Experiencia", href: "#experience" },
  { label: "Educación", href: "#education" },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-transform duration-300">
  <div class="card-glass relative mx-auto mt-4 flex max-w-3xl items-center justify-between rounded-full px-6 py-3 shadow-lg max-md:mx-4 max-md:px-4">
    <span class="text-sm font-bold text-white md:hidden">AFR</span>
    <div class="hidden items-center gap-6 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class="rounded-full px-4 py-1.5 text-sm text-gray-400 transition-colors duration-200 hover:text-white"
        >
          {link.label}
        </a>
      ))}
    </div>
    <button
      id="menu-btn"
      class="flex h-9 w-9 items-center justify-center rounded-full text-gray-300 transition-colors hover:text-white md:hidden"
      aria-label="Menú"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16" />
        <path d="M4 12h16" />
        <path d="M4 18h16" />
      </svg>
    </button>

    <div
      id="menu-overlay"
      class="absolute top-full left-0 right-0 mt-2 z-50 hidden flex-col rounded-2xl border border-dark-border bg-dark-bg p-4 shadow-xl"
    >
      {links.map((link) => (
        <a
          href={link.href}
          class="rounded-xl px-4 py-3 text-base text-gray-400 transition-colors duration-200 hover:bg-dark-card hover:text-white"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById("menu-btn");
  const overlay = document.getElementById("menu-overlay");
  let open = false;

  menuBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    open = !open;
    overlay?.classList.toggle("hidden", !open);
    overlay?.classList.toggle("flex", open);
  });

  overlay?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      open = false;
      overlay?.classList.add("hidden");
      overlay?.classList.remove("flex");
    });
  });

  document.addEventListener("click", (e) => {
    if (open && !e.target.closest("#navbar")) {
      open = false;
      overlay?.classList.add("hidden");
      overlay?.classList.remove("flex");
    }
  });

  let lastScroll = 0;
  const navbar = document.getElementById("navbar");

  window.addEventListener("scroll", () => {
    const currentScroll = window.scrollY;
    if (open) return;
    if (currentScroll > lastScroll && currentScroll > 100) {
      navbar.style.transform = "translateY(-120%)";
    } else {
      navbar.style.transform = "translateY(0)";
    }
    lastScroll = currentScroll;
  });
</script>
