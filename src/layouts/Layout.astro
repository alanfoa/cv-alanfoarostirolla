---
import "../styles/global.css";
interface Props {
  title?: string;
}

const { title = "Alan Foa Rostirolla — Fullstack Developer & CV" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="CV profesional de Alan Foa Rostirolla — Fullstack Developer & Soporte de Infraestructura. Especialista en TypeScript, NestJS, React, Node.js e IT." />
    <meta name="author" content="Alan Foa Rostirolla" />
    <meta property="og:title" content="Alan Foa Rostirolla — Fullstack Developer" />
    <meta property="og:description" content="CV profesional con proyectos, experiencia y stack tecnológico."
    />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
